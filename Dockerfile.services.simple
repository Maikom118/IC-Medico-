FROM node:20-bullseye

# Instalar dependências do sistema
RUN apt-get update && apt-get install -y \
    tesseract-ocr \
    tesseract-ocr-por \
    ffmpeg \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Criar diretórios
WORKDIR /app

# ============================================
# TRANSCRIÇÃO (Python)
# ============================================
COPY Transcricao/ /app/Transcricao/

# Instalar dependências Python
RUN pip3 install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    python-multipart \
    openai-whisper \
    httpx

# ============================================
# OCR (Node.js)
# ============================================
COPY OCR/ /app/OCR/

# Instalar dependências Node
WORKDIR /app/OCR
RUN npm install --production

# Copiar dados do Tesseract (português)
COPY por.traineddata /usr/share/tesseract-ocr/4.00/tessdata/ 2>/dev/null || true

# ============================================
# SCRIPT DE INICIALIZAÇÃO
# ============================================
WORKDIR /app
COPY start-services.sh /app/
RUN chmod +x /app/start-services.sh

# Expor portas
EXPOSE 8000 8300

# Iniciar ambos os serviços
CMD ["/app/start-services.sh"]
